{
  "manifest_version": 3,
  "name": "LinkedIn Assistant",
  "version": "0.2.8",
  "description": "Draft tailored connection messages, run a resume keyword-gap check, and find who you know at a company — from the post you're viewing.",
  "permissions": [
    "storage",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "LinkedIn Assistant"
  },
  "options_ui": {
    "page": "src/popup.html",
    "open_in_tab": true
  }
}
